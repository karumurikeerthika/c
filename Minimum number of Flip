#include <stdio.h>

int main() {
    int T;
    scanf("%d",&T);

    while(T--) {
        int N;
        scanf("%d",&N);

        int sum = 0;

        for(int i=0;i<N;i++) {
            int x;
            scanf("%d",&x);
            sum += x;
        }

        if(N % 2 != 0) {
            printf("-1\n");
        } else {
            if(sum < 0) sum = -sum;
            printf("%d\n", sum/2);
        }
    }

    return 0;
}
