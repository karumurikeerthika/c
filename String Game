#include <stdio.h>
#include <string.h>

int main() {
    int T;
    scanf("%d", &T);

    while(T--) {
        int N;
        char S[100005];

        scanf("%d", &N);
        scanf("%s", S);

        int zero = 0, one = 0;

        for(int i = 0; i < N; i++) {
            if(S[i] == '0') zero++;
            else one++;
        }

        int moves = zero < one ? zero : one;

        if(moves % 2 == 1)
            printf("Zlatan\n");
        else
            printf("Ramos\n");
    }

    return 0;
}
