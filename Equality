#include <stdio.h>

int main() {
    int T;
    scanf("%d",&T);

    while(T--) {
        int N;
        scanf("%d",&N);

        long long a[N];
        long long sum = 0;

        for(int i=0;i<N;i++) {
            scanf("%lld",&a[i]);
            sum += a[i];
        }

        long long S = sum / (N-1);

        for(int i=0;i<N;i++) {
            printf("%lld ", S - a[i]);
        }

        printf("\n");
    }

    return 0;
}
