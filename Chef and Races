#include <stdio.h>

int main() {
    int T;
    scanf("%d", &T);
    while(T--) {
        int X, Y, A, B;
        scanf("%d %d %d %d", &X, &Y, &A, &B);
        
        int medals = 0;
        if(X != A && X != B) medals++;
        if(Y != A && Y != B) medals++;
        
        printf("%d\n", medals);
    }
    return 0;
}
