#include <stdio.h>

int main() {
    int T;
    scanf("%d", &T);

    while(T--) {
        int N, A, B;
        scanf("%d %d %d", &N, &A, &B);

        int rounds = 0;

        while(N > 1) {
            N = N / 2;
            rounds++;
        }

        int total = rounds * A + (rounds - 1) * B;

        printf("%d\n", total);
    }

    return 0;
}
