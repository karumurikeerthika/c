#include <stdio.h>

int main() {
    int T;
    scanf("%d", &T);
    while(T--) {
        int X, Y, R;
        scanf("%d %d %d", &X, &Y, &R);

        int extra = R / 30;
        int total_sticks = X + extra;
        int plates = (total_sticks + Y - 1) / Y;

        printf("%d\n", plates);
    }
    return 0;
}
