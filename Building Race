#include <stdio.h>

int main() {
    int T;
    scanf("%d", &T);
    while(T--) {
        int A, B, X, Y;
        scanf("%d %d %d %d", &A, &B, &X, &Y);
        
        int chef_time = A * Y;
        int chefina_time = B * X;
        
        if(chef_time < chefina_time) {
            printf("Chef\n");
        } else if(chef_time > chefina_time) {
            printf("Chefina\n");
        } else {
            printf("Both\n");
        }
    }
    return 0;
}
