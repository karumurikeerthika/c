#include <stdio.h>

int main() {
    int T;
    scanf("%d", &T);

    while(T--) {
        int H, X, Y;
        scanf("%d %d %d", &H, &X, &Y);

        int remaining = H - Y;

        if(remaining <= 0) {
            printf("1\n");
        } else {
            int normal = (remaining + X - 1) / X;
            printf("%d\n", normal + 1);
        }
    }

    return 0;
}
