#include <stdio.h>

int main() {
    int T;
    scanf("%d", &T);

    while(T--) {
        int A, X, B, Y;
        scanf("%d %d %d %d", &A, &X, &B, &Y);

        if (A * Y > B * X)
            printf("ALICE\n");
        else if (A * Y < B * X)
            printf("BOB\n");
        else
            printf("EQUAL\n");
    }

    return 0;
}
