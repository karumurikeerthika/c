#include <stdio.h>

int main() {
    int T;
    scanf("%d",&T);

    while(T--){
        int N;
        scanf("%d",&N);

        int P[200005];

        for(int i=1;i<=2*N;i++)
            scanf("%d",&P[i]);

        long long swaps=0;
        int pos=1;

        for(int i=1;i<=2*N;i++){
            if(P[i] <= N){
                swaps += i - pos;
                pos++;
            }
        }

        printf("%lld\n",swaps);
    }

    return 0;
}
