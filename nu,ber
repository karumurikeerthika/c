#include <stdio.h>

int main() {
    int T;
    scanf("%d",&T);

    while(T--) {
        int N;
        scanf("%d",&N);

        int g[N];
        for(int i=0;i<N;i++)
            scanf("%d",&g[i]);

        int minGoal = g[0];
        int maxDiff = -1;

        for(int i=1;i<N;i++) {
            int diff = g[i] - minGoal;

            if(diff > maxDiff)
                maxDiff = diff;

            if(g[i] < minGoal)
                minGoal = g[i];
        }

        if(maxDiff <= 0)
            printf("UNFIT\n");
        else
            printf("%d\n",maxDiff);
    }

    return 0;
}
