#include <stdio.h>
#include <math.h>

int main() {
    int T;
    scanf("%d",&T);

    while(T--) {
        int N, prime = 1;
        scanf("%d",&N);

        if(N == 1)
            prime = 0;

        for(int i = 2; i <= sqrt(N); i++) {
            if(N % i == 0) {
                prime = 0;
                break;
            }
        }

        if(prime)
            printf("yes\n");
        else
            printf("no\n");
    }

    return 0;
}
