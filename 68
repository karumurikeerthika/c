#include <stdio.h>
#include <string.h>

int main() {
    int T;
    scanf("%d",&T);

    while(T--) {
        int N;
        scanf("%d",&N);

        int start = 0, ltime = 0;
        char s[20];

        for(int i=0;i<N;i++) {
            scanf("%s",s);

            if(strcmp(s,"START38")==0)
                start++;
            else
                ltime++;
        }

        printf("%d %d\n",start,ltime);
    }

    return 0;
}
