#include <stdio.h>

int main() {
    int n;
    scanf("%d",&n);

    int s1=0,s2=0;
    int maxLead=0,winner=0;

    for(int i=0;i<n;i++){
        int a,b;
        scanf("%d %d",&a,&b);

        s1 += a;
        s2 += b;

        int lead;
        int leader;

        if(s1 > s2){
            lead = s1 - s2;
            leader = 1;
        }
        else{
            lead = s2 - s1;
            leader = 2;
        }

        if(lead > maxLead){
            maxLead = lead;
            winner = leader;
        }
    }

    printf("%d %d\n",winner,maxLead);

    return 0;
}
